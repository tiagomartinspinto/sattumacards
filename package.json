{
  "name": "sattumacards",
  "version": "1.0.0",
  "description": "Collaborative bilingual card game for exploring teaching situations in shared multiplayer rooms",
  "main": "server.js",
  "scripts": {
    "check": "node --check server.js && node scripts/check-client-modules.js && npm run check:decks && npm run smoke",
    "check:decks": "node scripts/check-decks.js",
    "dev": "node --watch server.js",
    "lint": "npm run check",
    "smoke": "node scripts/smoke-check.js",
    "test": "npm run check",
    "start": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "socket.io": "^4.7.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiagomartinspinto/sattumacards.git"
  }
}
